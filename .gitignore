# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/

# =============================================================================
# Trained model artifacts — large, regeneratable from code + dataset.
# Total runs/ tree is ~10+ GB once checkpoints accumulate; per-checkpoint files
# are 100-500 MB and exceed GitHub's 100 MB/file limit. Regenerate by re-running
# `python scripts/train.py --routing X --backbone Y --target Z --loss W`.
# =============================================================================
runs/**/checkpoints/
runs/**/*.pt
runs/**/*.pt.tmp

# =============================================================================
# Training / queue logs — regeneratable verbatim from rerunning the launcher.
# The per-run RECORD lives in config.json + final.json + eval_results.json +
# metrics.jsonl, all of which we DO commit (see "explicit keeps" below).
# =============================================================================
runs/*.log
runs/*.train.log
runs/*.eval.log
runs/preflight_*.log
runs/ablation_queue.log
runs/tier1_cnn.log
runs/cells_6_7.log
runs/recover_evals.log

# Stray scratch files
runs/_runs_compiled.json
runs/last_launch.log

# =============================================================================
# OS / IDE noise
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# Explicit keeps — these are intentionally tracked, do not list above:
#   runs/manifest.tsv             (cross-run TSV summary)
#   runs/<run_id>/config.json     (frozen merged config)
#   runs/<run_id>/final.json      (wall time, param counts, final losses)
#   runs/<run_id>/eval_results.json  (alpha/zeta probe scores)
#   runs/<run_id>/metrics.jsonl   (per-step training trajectory; ~1-3 MB each)
#   runs/<run_id>/features/meta.json (split sizes; the .pt files are excluded)
#   results/                       (analysis docs + _runs.json — all small text)
# Tests are gitignored via tests/.gitignore (smoke-only, not part of repo).
# =============================================================================
